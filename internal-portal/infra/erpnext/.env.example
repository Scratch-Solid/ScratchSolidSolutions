# ERPNext Docker Environment Configuration
# Copy this file to .env and update all secrets before running docker compose up

# MariaDB
MYSQL_ROOT_PASSWORD=change-me-to-a-secure-password
MYSQL_DATABASE=_17d34f6a7c2d8a9

# Frappe Site (used during site creation)
SITE_NAME=scratchsolid.local
ADMIN_PASSWORD=change-me-to-a-secure-admin-password

# Install apps into the site (space-separated)
INSTALL_APPS=erpnext

# Optional: S3 backup credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BUCKET_NAME=
# REGION=
# ENDPOINT_URL=

# Optional: Email SMTP for ERPNext notifications
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_SENDER=

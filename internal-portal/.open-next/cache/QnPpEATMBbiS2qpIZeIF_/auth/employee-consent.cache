{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/employee-consent/layout,_N_T_/auth/employee-consent/page,_N_T_/auth/employee-consent"},"segmentPaths":["/_tree","/_full","/auth/employee-consent/__PAGE__","/auth/employee-consent","/auth","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0qr~fop.uw.-5.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0ht900cau6_ur.js\"/><script src=\"/_next/static/chunks/02i7dfk78~t~2.js\" async=\"\"></script><script src=\"/_next/static/chunks/0n~dq4kpx9xxx.js\" async=\"\"></script><script src=\"/_next/static/chunks/0.3eeb2kqn_qv.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0~5s1w~r4ubhu.js\" async=\"\"></script><script src=\"/_next/static/chunks/0dbhjjzl8qfwv.js\" async=\"\"></script><script src=\"/_next/static/chunks/07_tecc7lgj4u.js\" async=\"\"></script><title>Scratch Solid Solutions - Internal Portal</title><meta name=\"description\" content=\"Internal portal for Scratch Solid Solutions staff and management\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen flex items-center justify-center px-4\"><div class=\"glass-panel max-w-2xl w-full\"><div class=\"text-center mb-8\"><h1 class=\"text-3xl font-bold mb-2\" style=\"color:var(--text-h)\">Scratch Solid Solutions</h1><p class=\"text-lg font-medium\" style=\"color:var(--text)\">Employee Background Check Consent Form</p></div><form class=\"space-y-6\"><div><label class=\"block text-sm font-bold mb-2\">Position Applied For: __________________________</label><input type=\"text\" class=\"w-full\" required=\"\" placeholder=\"Enter position applied for\" name=\"positionAppliedFor\" value=\"\"/></div><div class=\"border-t pt-6\"><h2 class=\"text-xl font-bold mb-4\">Applicant Details</h2><div class=\"space-y-4\"><div><label class=\"block text-sm font-bold mb-2\">Full Name: __________________________</label><input type=\"text\" class=\"w-full\" required=\"\" placeholder=\"Enter full name\" name=\"fullName\" value=\"\"/></div><div><label class=\"block text-sm font-bold mb-2\">(ID / Passport Number: __________________________</label><input type=\"text\" class=\"w-full\" required=\"\" placeholder=\"Enter ID or passport number\" name=\"idPassportNumber\" value=\"\"/></div><div><label class=\"block text-sm font-bold mb-2\">Contact Number: __________________________</label><input type=\"tel\" class=\"w-full\" required=\"\" placeholder=\"Enter contact number\" name=\"contactNumber\" value=\"\"/></div></div></div><div class=\"border-t pt-6\"><h2 class=\"text-xl font-bold mb-4\">Consent &amp; Authorisation</h2><div class=\"text-sm leading-relaxed space-y-2\"><p>I, the undersigned, hereby give written, informed consent to Scratch Solid Solutions to conduct background checks relevant to my application for employment.</p><p>I understand that these checks may include:</p><ul class=\"list-disc list-inside ml-4 space-y-1\"><li>Identity verification</li><li>Criminal record check (where relevant to the position)</li><li>Reference and employment history checks</li></ul><p>I acknowledge that:</p><ul class=\"list-disc list-inside ml-4 space-y-1\"><li>All information will be processed in accordance with the Protection of Personal Information Act (POPIA)</li><li>Information collected will only be used for employment‑related purposes</li><li>My personal information will be stored securely and confidentially</li><li>I may request access to my information or withdraw consent in writing</li></ul><p class=\"font-semibold\">I confirm that the information I have provided is true and correct.</p></div></div><div class=\"border-t pt-6 space-y-4\"><div class=\"flex items-start\"><input type=\"checkbox\" id=\"applicantSignature\" class=\"mt-1 mr-3 w-5 h-5\" name=\"applicantSignature\"/><div><label for=\"applicantSignature\" class=\"block text-sm font-bold\">Applicant Signature (Tick to confirm signature)</label><p class=\"text-xs text-gray-600\">By ticking this box, I confirm my electronic signature</p></div></div><div><label class=\"block text-sm font-bold mb-2\">Date: <!-- -->4/27/2026, 12:34:07 PM</label><p class=\"text-xs text-gray-600\">Date and time captured by the system</p></div><div><label class=\"block text-sm font-bold mb-2\">Witness / Company Representative: Xolani Jason Tshaka</label></div></div><div class=\"flex gap-4 pt-6 border-t\"><button type=\"submit\" class=\"flex-1 primary-button\">I Consent</button><button type=\"button\" class=\"flex-1 secondary-button\">Decline</button></div></form></div></div><!--$--><!--/$--><script src=\"/_next/static/chunks/0ht900cau6_ur.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"default\\\"]\\n4:I[47257,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"ClientPageRoot\\\"]\\n5:I[87086,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\",\\\"/_next/static/chunks/07_tecc7lgj4u.js\\\"],\\\"default\\\"]\\n8:I[97367,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"OutletBoundary\\\"]\\n9:\\\"$Sreact.suspense\\\"\\nc:I[97367,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"ViewportBoundary\\\"]\\ne:I[97367,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"MetadataBoundary\\\"]\\n10:I[68027,[\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/0qr~fop.uw.-5.css\\\",\\\"style\\\"]\\n\"])</s
# Example environment variables for Directus + integration
# Copy to .env and fill in real values for production

# Directus
DIRECTUS_KEY=supersecretkey
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin1234
DIRECTUS_URL=http://localhost:8055
DIRECTUS_API_TOKEN=

# PostgreSQL (for prod)
DATABASE_URL=

# Cloudflare Pages/Workers
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Zoho Books
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Other secrets
JWT_SECRET=

# Production Environment Variables for Marketing Site

# REQUIRED - Authentication (generate with: openssl rand -base64 48)
JWT_SECRET=

# Cloudflare R2 (for uploads)
R2_BUCKET=scratchsolid-uploads
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key

# Zoho Books Integration
ZOHO_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Directus CMS
DIRECTUS_URL=https://cms.scratchsolid.com
DIRECTUS_TOKEN=your-production-token

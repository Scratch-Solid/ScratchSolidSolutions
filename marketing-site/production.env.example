# Production Environment Variables for Marketing Site
# Copy this file to .env.local for local development or configure in Cloudflare Worker secrets for production

# REQUIRED - Authentication (generate with: openssl rand -base64 48)
JWT_SECRET=

# Cloudflare R2 (for file uploads)
R2_BUCKET=scratchsolid-uploads
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Zoho Books Integration (for payment processing and invoicing)
ZOHO_ORG_ID=your-zoho-organization-id
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# Directus CMS (for content management)
DIRECTUS_URL=https://cms.scratchsolid.com
DIRECTUS_TOKEN=your-directus-admin-token
DIRECTUS_API_TOKEN=your-directus-api-token

# Resend Email Service (for password reset and transactional emails)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Cloudflare D1 Database (configured in wrangler.jsonc)
# Database binding: scratchsolid_db
# Database ID: 0b0b6006-1b2d-4ab1-8909-dc684666e6d3

# Application URLs
NEXT_PUBLIC_BASE_URL=https://scratchsolidsolutions.org
NEXT_PUBLIC_API_URL=https://api.scratchsolidsolutions.org
NEXT_PUBLIC_DIRECTUS_URL=https://cms.scratchsolid.com

# API Configuration (for demo purposes only - not for production)
NEXT_PUBLIC_API_TOKEN=

# Environment
NODE_ENV=production

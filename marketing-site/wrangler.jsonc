{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "scratchsolidsolutions",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "scratchsolid_db",
      "database_name": "scratchsolid-db",
      "database_id": "0b0b6006-1b2d-4ab1-8909-dc684666e6d3"
    }
  ],
  "vars": {
    "JWT_SECRET": "scratchsolid-solutions-jwt-secret-2024-secure-key-change-in-production",
    "RESEND_API_KEY": ""
  },
  "observability": {
    "enabled": true
  }
}

# Scratch Solid Solutions - Environment Variables Template
# Copy this file to .env.local in each project root and fill in real values

# Database
scratchsolid_db=

# JWT
JWT_SECRET=change-me-in-production-min-32-characters-long

# WhatsApp
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# Email (SendGrid / AWS SES)
EMAIL_API_KEY=
EMAIL_FROM=noreply@scratchsolid.co.za

# Zoho Books
ZOHO_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Cal.com (marketing-site server-side booking hand-off -> n8n -> portal)
# When CALCOM_API_KEY is set AND an event type is resolvable, a marketing
# booking will also create a Cal.com booking, which triggers the n8n
# ingestion workflow that creates the portal job + auto-assigns a cleaner.
# Leave blank to disable (bookings stay local; calcom_status = 'not_sent').
CALCOM_API_KEY=
# API base URL. Self-hosted: https://booking.scratchsolidsolutions.org/api/v2
# Cal.com cloud: https://api.cal.com/v2 (default if unset)
CALCOM_API_URL=https://api.cal.com/v2
# Default Cal.com event type id used when no per-service mapping matches.
CALCOM_DEFAULT_EVENT_TYPE_ID=
# Optional JSON map of marketing service_type -> Cal.com eventTypeId, e.g.
# {"standard":101,"deep_clean":102,"move_in":103,"move_out":104}
CALCOM_EVENT_TYPE_MAP=
# Timezone used to interpret the client's chosen date/time (default Africa/Johannesburg)
CALCOM_TIMEZONE=Africa/Johannesburg

# CSRF
CSRF_SECRET=change-me-in-production-min-32-characters-long

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

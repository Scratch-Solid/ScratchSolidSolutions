# Scratch Solid Solutions - Environment Variables Template
# Copy this file to .env.local in each project root and fill in real values

# Database
scratchsolid_db=

# JWT
JWT_SECRET=change-me-in-production-min-32-characters-long

# Directus CMS
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=

# WhatsApp
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# Email (SendGrid / AWS SES)
EMAIL_API_KEY=
EMAIL_FROM=noreply@scratchsolid.co.za

# Zoho Books
ZOHO_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# CSRF
CSRF_SECRET=change-me-in-production-min-32-characters-long

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

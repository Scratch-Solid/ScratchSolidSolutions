# ═══════════════════════════════════════════════════════════════════
# ScratchSolid 2.0 — Unified Infrastructure Environment
# Copy this file to .env and fill in ALL secrets before deployment.
# Generate secrets with: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════

# ─── TRAEFIK / LET'S ENCRYPT ───
ACME_EMAIL=admin@scratchsolidsolutions.org

# ─── CAL.COM ───
CALCOM_DB_USER=scratch_admin
CALCOM_DB_PASSWORD=<generate-32-char-hex>
CALCOM_DB_NAME=calcom
CALCOM_WEBAPP_URL=https://booking.scratchsolidsolutions.org
CALCOM_NEXTAUTH_SECRET=<generate-32-char-hex>
CALCOM_ENCRYPTION_KEY=<generate-32-char-hex>

# Email provider for Cal.com notifications (Resend)
EMAIL_FROM=noreply@scratchsolidsolutions.org
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=<your-resend-api-key>

# ─── N8N ───
N8N_DB_USER=n8n
N8N_DB_PASSWORD=<generate-32-char-hex>
N8N_DB_NAME=n8n
N8N_ENCRYPTION_KEY=<generate-32-char-hex>
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=scratchadmin
N8N_BASIC_AUTH_PASSWORD=<generate-32-char-hex>
N8N_WEBHOOK_URL=https://n8n.scratchsolidsolutions.org/
N8N_IP_WHITELIST=0.0.0.0/0

# ─── ERPNEXT ───
ERPNEXT_SITE_NAME=scratchsolid.local
ERPNEXT_DB_ROOT_PASSWORD=<generate-32-char-hex>
ERPNEXT_DB_NAME=_17d34f6a7c2d8a9

# ─── SHARED ───
TZ=Africa/Johannesburg
RESEND_API_KEY=<your-resend-api-key>

# ─── INTERNAL PORTAL WEBHOOK SECRET (n8n ↔ Portal) ───
INTERNAL_PORTAL_N8N_WEBHOOK_SECRET=<generate-32-char-hex>

# ─── R2 BACKUP CONFIGURATION ───
# Create these in Cloudflare R2 dashboard (or use existing portal buckets)
R2_ACCESS_KEY_ID=<your-r2-access-key>
R2_SECRET_ACCESS_KEY=<your-r2-secret-key>
R2_BUCKET_NAME=scratchsolid-backups
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
BACKUP_RETENTION_DAYS=30

# ─── MARKETING SITE (Next.js on Hetzner) ───
MARKETING_DB_USER=marketing
MARKETING_DB_PASSWORD=<generate-32-char-hex>
MARKETING_DB_NAME=marketing
MARKETING_BASE_URL=https://scratchsolidsolutions.org
MARKETING_API_URL=https://api.scratchsolidsolutions.org/api
# Uploads bucket (Cloudflare R2 over S3 API, or self-hosted MinIO)
MARKETING_UPLOADS_BUCKET=scratchsolid-uploads
R2_PUBLIC_BASE=https://uploads.scratchsolidsolutions.org
S3_REGION=auto
S3_FORCE_PATH_STYLE=false
# App secrets (must match values previously set as Cloudflare secrets)
JWT_SECRET=<generate-32-char-hex>
CSRF_SECRET=<generate-32-char-hex>
# Zoho Books/CRM (financial source of truth)
ZOHO_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ─── INTERNAL PORTAL (Next.js on Hetzner) ───
PORTAL_DB_USER=portal
PORTAL_DB_PASSWORD=<generate-32-char-hex>
PORTAL_DB_NAME=portal
PORTAL_BASE_URL=https://portal.scratchsolidsolutions.org
PORTAL_UPLOADS_BUCKET=scratchsolid-uploads
PORTAL_PHOTOS_BUCKET=scratchsolid-uploads
# ERPNext API (cleaner shift assignments / payroll)
ERPNEXT_BASE_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ─── META WHATSAPP CLOUD API (Phase 5) ───
# META_APP_ID=<your-meta-app-id>
# META_APP_SECRET=<your-meta-app-secret>
# META_WABA_ID=<your-waba-id>
# META_PHONE_NUMBER_ID=<your-phone-number-id>
# META_ACCESS_TOKEN=<your-permanent-access-token>

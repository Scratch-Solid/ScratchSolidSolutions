# .gitignore for monorepo
node_modules/
dist/
.env
.env.secrets

# Generated test artifacts (Playwright/Selenium) — never commit to production repo
test-results/
playwright-report/
jest-out.txt

# Debug / scratch artifacts — never commit (kept out of the production repo)
tsc-*.txt
*.log
db_query*.txt
login-debug-response.txt
temp_deploy.txt
services_export.json
test_*.json
test_*.bat
.vscode/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.sqlite3
*.db
.DS_Store
.idea/
.next/
.open-next/
out/
build/
coverage/
.wrangler/
frontend/node_modules/
backend-worker/node_modules/
marketing-site/.next/
marketing-site/node_modules/

# SQL files with sensitive data (but keep migrations)
*_admin.sql
*_user.sql
*_password.sql
update_password.sql
create_*.sql
clear_*.sql
seed_*.sql
copy_*.sql
test_*.sql
fix_*.sql
